FROM node:22-slim

# 作業ディレクトリ
WORKDIR /app

# 必要なシステムパッケージをインストール
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Gemini CLI と Python ライブラリをインストール
RUN npm install -g @google/gemini-cli
# イメージ作成時にはファイルがマウントされないため，コピーが必要
COPY agent/requirements.txt .
# システム全体へのパッケージインストールを許可する
RUN pip3 install --break-system-packages -r requirements.txt

# Gemini CLI が利用する設定ディレクトリを事前作成
RUN mkdir -p /root/.gemini /app/workspace

# uvicornを使ってFastAPIを起動
CMD ["uvicorn", "agent.api:app", "--host", "0.0.0.0", "--port", "8000"]
