FROM python:3.14-slim

WORKDIR /app

# uv (Python パッケージマネージャ) をインストール
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Node.js (Gemini CLI 用) をインストール
RUN apt-get update && apt-get install -y curl ca-certificates && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Gemini CLI をグローバルインストール
RUN npm install -g @google/gemini-cli

# Python 依存のインストール (pyproject.toml を先にコピーしてキャッシュを活かす)
COPY pyproject.toml .
RUN uv sync

# アプリ本体をイメージ内に取り込む（ランタイムでホストディレクトリをマウントしない）
COPY . .

# Gemini CLI が利用する設定ディレクトリを事前作成
RUN mkdir -p /root/.gemini

# uvicorn を使って FastAPI を起動
CMD ["uv", "run", "uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8000"]
