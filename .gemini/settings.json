{
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    }
  },
  "agents": {
    "overrides": {
      "browser_agent": {
        "enabled": false
      },
      "codebase_investigator": {
        "enabled": false
      },
      "cli_help": {
        "enabled": true
      }
    },
    "browser": {
      "headless": true
    }
  },
  "ui": {
    "theme": "Default Light"
  },
  "experimental": {
    "adk": {
      "agentSessionNoninteractiveEnabled": true
    }
  },
  "general": {
    "sessionRetention": {
      "maxAge": "360d"
    }
  },
  "tools": {
    "shell": {
      "interactive": false
    },
    "core": [
      "web_fetch",
      "web_fetch",
      "save_memory",
      "write_todos",
      "activate_skill",
      "complete_task"
    ],
    "exclude": [
      "list_directory",
      "read_file",
      "read_many_files",
      "write_file",
      "replace",
      "glob",
      "grep_search",
      "ask_user"
    ]
  },
  "model": {
    "compressionThreshold": 0.7
  },
  "mcp": {
    "allowed": [
      "agent-tools"
    ]
  },
  "mcpServers": {
    "agent-tools": {
      "httpUrl": "http://mcp-tools:9001/mcp",
      "trust": false,
      "timeout": 120000,
      "includeTools": [
        "fetch_page",
        "ir_fetch",
        "web_search",
        "normalize_financials",
        "stock_code_search",
        "notion_search_company",
        "notion_add_company",
        "notion_upsert_company",
        "notion_get_content",
        "notion_append_research",
        "notion_episode_list_records",
        "notion_episode_get_content",
        "notion_task_list_records",
        "notion_task_get_schema",
        "notion_add_task",
        "notion_update_task",
        "notion_append_task_content",
        "gmail_search_emails",
        "memory_store",
        "memory_search",
        "memory_delete"
      ]
    }
  }
}